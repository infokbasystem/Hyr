<?xml version="1.0" encoding="utf-8"?>
<Report Width="17cm" Name="Invoice" SnapGridSize="0.1cm" xmlns="http://schemas.telerik.com/reporting/2025/2.0">
  <DataSources>
    <ObjectDataSource ParameterValues="null" Name="InvoiceDataSource" />
  </DataSources>
  <Items>
    <PageHeaderSection Height="2.1cm" Name="pageHeaderSection1">
      <Items>
        <PictureBox Image="" Width="4.9cm" Height="1.3cm" Left="0.7cm" Top="0.3cm" Sizing="ScaleProportional" MimeType="" Name="pictureBox1" />
        <TextBox Width="3.4cm" Height="0.7cm" Left="9.9cm" Top="0.6cm" Value="Faktura" Angle="0" Name="textBox3">
          <Style Color="128, 128, 128">
            <Font Size="16pt" Bold="True" />
          </Style>
        </TextBox>
      </Items>
    </PageHeaderSection>
    <DetailSection Height="9.7cm" Name="detailSection1">
      <Items>
        <TextBox Width="3cm" Height="0.5cm" Left="0.5cm" Top="0.4cm" Value="Mottagare" Name="textBox1">
          <Style Color="128, 128, 128">
            <Font Size="9pt" Bold="True" />
          </Style>
        </TextBox>
        <TextBox Width="4.4cm" Height="0.5cm" Left="0.5cm" Top="1.1cm" Value="=Fields.CustomerName" Name="textBox2" />
      </Items>
    </DetailSection>
    <PageFooterSection Height="2cm" Name="pageFooterSection1" />
  </Items>
  <PageSettings PaperKind="A4" Landscape="False">
    <Margins>
      <MarginsU Left="2cm" Right="2cm" Top="2cm" Bottom="2cm" />
    </Margins>
  </PageSettings>
  <StyleSheet>
    <StyleRule>
      <Style>
        <Padding Left="2pt" Right="2pt" />
      </Style>
      <Selectors>
        <TypeSelector Type="TextItemBase" />
        <TypeSelector Type="HtmlTextBox" />
      </Selectors>
    </StyleRule>
    <StyleRule>
      <Style Color="Black">
        <Font Name="Tahoma" Size="9pt" />
        <BorderStyle Default="Solid" />
        <BorderColor Default="Black" />
        <BorderWidth Default="1px" />
      </Style>
      <Selectors>
        <StyleSelector Type="Table" StyleName="Normal.TableNormal" />
      </Selectors>
    </StyleRule>
    <StyleRule>
      <Style>
        <Font Name="Tahoma" Size="9pt" />
        <BorderStyle Default="Solid" />
        <BorderColor Default="Black" />
        <BorderWidth Default="1px" />
      </Style>
      <Selectors>
        <DescendantSelector>
          <Selectors>
            <TypeSelector Type="Table" />
            <StyleSelector Type="ReportItem" StyleName="Normal.TableBody" />
          </Selectors>
        </DescendantSelector>
      </Selectors>
    </StyleRule>
    <StyleRule>
      <Style VerticalAlign="Middle">
        <Font Name="Tahoma" Size="10pt" />
        <BorderStyle Default="Solid" />
        <BorderColor Default="Black" />
        <BorderWidth Default="1px" />
      </Style>
      <Selectors>
        <DescendantSelector>
          <Selectors>
            <TypeSelector Type="Table" />
            <StyleSelector Type="ReportItem" StyleName="Normal.TableHeader" />
          </Selectors>
        </DescendantSelector>
      </Selectors>
    </StyleRule>
  </StyleSheet>
</Report>